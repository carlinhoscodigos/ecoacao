# Porta onde o Express escuta (Tailscale Funnel / localhost)
PORT=3000

# Frontend em desenvolvimento (Vite)
FRONTEND_URL_DEV=http://localhost:5173

# Frontend no Vercel (sem barra no fim)
# Em desenvolvimento, se omitir, o servidor assume http://localhost:5173 para FRONTEND_URL_DEV
FRONTEND_URL_PROD=https://ecoacao-gilt.vercel.app

# Compatível com .env antigo — se FRONTEND_URL_PROD estiver vazio, este valor é usado
# FRONTEND_URL=https://ecoacao-gilt.vercel.app

# Opcional: production | development (afeta mensagens de erro na API)
# NODE_ENV=production
