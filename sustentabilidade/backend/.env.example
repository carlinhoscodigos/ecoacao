# Porta onde o Express escuta (Tailscale Funnel / localhost)
PORT=3000

# Frontend em desenvolvimento (Vite)
FRONTEND_URL_DEV=http://localhost:5173

# Frontend no Vercel (sem barra no fim)
FRONTEND_URL_PROD=https://ecoacao-gilt.vercel.app

# Compatível com .env antigo — se FRONTEND_URL_PROD estiver vazio, este valor é usado
# FRONTEND_URL=https://ecoacao-gilt.vercel.app

# JWT (obrigatório em produção)
JWT_SECRET=3Xx88Li9Gb0AcmgapDxyEX8RfOlfHZ95Xgsds6BBrLU
# SQLite (ficheiro local; criado automaticamente)
# DATABASE_PATH=./data/ecoacao.db

# Segredo para POST /api/migration/import-localstorage (recomendado em produção).
# O frontend envia o mesmo valor em VITE_IMPORT_SECRET na migração única.
IMPORT_SECRET=

# Seed inicial do admin.
# Em produção, altere pelo menos a senha e, se quiser, também o e-mail.
# ADMIN_SEED_EMAIL=carlosdanielterciario@gmail.com
# ADMIN_SEED_PASSWORD=carloslos12
# ADMIN_SEED_NAME=Administrador do Sistema

# Opcional: production | development (afeta mensagens de erro na API)
# NODE_ENV=production
